<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PetTok - Personalizza per il tuo Cane</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            padding: 20px;
            background-color: #fadadd; /* rosa pastello */
            text-align: center;
        }
        .hidden { display: none; }
        .product, .form-section { margin-bottom: 20px; }
        .product img {
            max-width: 100px;
            display: block;
            margin: 10px auto;
        }
        .highlight {
            font-weight: bold;
            text-decoration: underline;
        }
        label, input, button {
            display: block;
            margin: 10px auto;
        }
        button {
            padding: 10px 15px;
            cursor: pointer;
        }
        img#logo {
            max-width: 150px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <img id="logo" src="URL_DEL_TUO_LOGO" alt="Logo PetTok">
    <h1>PetTok</h1>

    <div class="product">
        <h2 class="highlight">Seleziona il tuo prodotto</h2>
        <label>
            <input type="radio" name="product" value="ciotola" onclick="showForm('ciotola')">
            Ciotola
            <img src="URL_IMMAGINE_CIOTOLA" alt="Ciotola">
        </label>
        <label>
            <input type="radio" name="product" value="targhetta" onclick="showForm('targhetta')">
            Targhetta
            <img src="URL_IMMAGINE_TARGHETTA" alt="Targhetta">
        </label>
        <label>
            <input type="radio" name="product" value="completo" onclick="showForm('completo')">
            Ciotola + Targhetta (Pacchetto Completo)
            <img src="URL_IMMAGINE_COMPLETO" alt="Completo">
        </label>
    </div>

    <div id="form-section" class="form-section hidden">
        <h2>Inserisci i dettagli</h2>
        <form>
            <label for="pet-name">Nome del cane:</label>
            <input type="text" id="pet-name" name="pet-name" required>
            <label for="phone">Numero di telefono:</label>
            <input type="tel" id="phone" name="phone" required>
            <button type="submit">Prenota</button>
        </form>
    </div>

    <script>
        function showForm(selection) {
            document.getElementById('form-section').classList.remove('hidden');
        }
    </script>
</body>
</html>
